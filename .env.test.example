# Copy this file to .env.test and fill in real values.
# .env.test is gitignored — NEVER commit it.

# The same Supabase project as dev/prod (or a dedicated test project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# A test user that ALREADY EXISTS in Supabase with saldo already configured.
# Used for E2E flows that skip onboarding.
TEST_USER_EMAIL=test@miluka.dev
TEST_USER_PASSWORD=TestPassword123!

# A fresh email prefix: tests will register TEST_FRESH_PREFIX+<timestamp>@miluka.dev
# Supabase must have email confirmation DISABLED (Auth → Settings → Confirm email: off)
TEST_FRESH_PREFIX=fresh_test
